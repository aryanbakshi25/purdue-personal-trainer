 rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────────
    // Users can only read/write their own documents.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Schedule blocks sub-collection
      match /scheduleBlocks/{blockId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Plans sub-collection
      match /plans/{planId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Cache ─────────────────────────────────────────────────────
    // Facility usage cache is readable by any authenticated user.
    // Only Cloud Functions (admin SDK) can write to it.
    match /cache/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK bypasses rules
    }

    // ── Default deny ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
